{
  "primaryKey": "id",
  "type": "object",
  "properties": {
    "id":            { "type": "string", "generate": { "type": "uuid", "format": "short" } },
    "createdAt":     { "type": "string", "generate": { "type": "datetime" } },
    "submitterName": { "type": "string" },
    "note":          { "type": "string" },
    "status":        { "type": "string" },
    "aiSummary":     { "type": "string" },
    "aiCategory":    { "type": "string" }
  },
  "required": ["submitterName", "note"]
}